class YOLODetector:
    """Обёртка для YOLO модели"""
    
    def __init__(self, model_path: str = None, auto_download: bool = True):
        if not YOLO_AVAILABLE:
            raise ImportError("Ultralytics не установлен")
        
        self.device = "cuda" if torch.cuda.is_available() else "cpu"
        
        # Поиск модели
        if model_path is None or not os.path.exists(model_path):
            possible_paths = [
                "runs/yolo26/leaf_detection/weights/best.pt",
                "yolo26n.pt",
                "best.pt"
            ]
            for path in possible_paths:
                if os.path.exists(path):
                    model_path = path
                    break
        
        if model_path and os.path.exists(model_path):
            self.model = YOLO(model_path)
            print(f"✅ YOLO загружен: {model_path}")
        elif auto_download:
            print("📥 Загрузка предобученной модели YOLO26...")
            self.model = YOLO("yolo26n.pt")
        else:
            raise FileNotFoundError("Модель YOLO не найдена")
        
        self.model.to(self.device)
        print(f"🚀 YOLO на устройстве: {self.device}")
    
    def detect(self, image: np.ndarray, conf_threshold: float = 0.25) -> List[Dict]:
        """
        Детекция листьев и повреждений
        
        Args:
            image: изображение BGR
            conf_threshold: порог уверенности
        
        Returns:
            список детекций
        """
        results = self.model(image, conf=conf_threshold, verbose=False)
        
        detections = []
        if len(results) > 0 and results[0].boxes is not None:
            boxes = results[0].boxes
            for box in boxes:
                x1, y1, x2, y2 = box.xyxy[0].tolist()
                confidence = float(box.conf[0])
                class_id = int(box.cls[0])
                class_name = 'leaf' if class_id == 0 else 'damage'
                
                detections.append({
                    'class': class_name,
                    'class_id': class_id,
                    'bbox': [int(x1), int(y1), int(x2), int(y2)],
                    'confidence': confidence
                })
        
        return detections
    
    def train(self, dataset_yaml: str, epochs: int = 100, imgsz: int = 640,
              batch: int = 4, device: str = "cpu") -> str:
        """
        Обучение модели YOLO
        
        Args:
            dataset_yaml: путь к YAML конфигу датасета
            epochs: количество эпох
            imgsz: размер изображения
            batch: размер батча
            device: устройство (cpu/cuda)
        
        Returns:
            путь к лучшей модели
        """
        print(f"🚀 Начало обучения YOLO на {epochs} эпох...")
        
        results = self.model.train(
            data=dataset_yaml,
            epochs=epochs,
            imgsz=imgsz,
            batch=batch,
            device=device,
            workers=0,
            patience=20,
            save=True,
            project="runs/yolo26",
            name="leaf_detection",
            exist_ok=True,
            verbose=True
        )
        
        best_model_path = "runs/yolo26/leaf_detection/weights/best.pt"
        print(f"✅ Обучение завершено! Модель: {best_model_path}")
        
        # Обновляем модель
        self.model = YOLO(best_model_path)
        
        return best_model_path


