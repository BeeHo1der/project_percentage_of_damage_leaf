class DatasetSplitter:
    """Класс для разделения датасета на train/val/test"""
    
    @staticmethod
    def split_yolo_dataset(source_images_dir: str, source_labels_dir: str, 
                          output_dir: str = "dataset_yolo",
                          train_ratio: float = 0.7, 
                          val_ratio: float = 0.2, 
                          test_ratio: float = 0.1) -> Dict:
        """
        Разделение датасета в формате YOLO
        
        Args:
            source_images_dir: папка с исходными изображениями
            source_labels_dir: папка с txt-разметкой
            output_dir: выходная папка
            train_ratio: доля обучения (0.7)
            val_ratio: доля валидации (0.2)
            test_ratio: доля тестирования (0.1)
        """
        
        # Получаем список всех изображений
        image_extensions = ['.jpg', '.jpeg', '.png', '.bmp', '.tiff']
        all_images = [f for f in os.listdir(source_images_dir) 
                      if os.path.splitext(f)[1].lower() in image_extensions]
        
        # Проверяем наличие разметки
        valid_images = []
        for img in all_images:
            name = os.path.splitext(img)[0]
            label_path = os.path.join(source_labels_dir, f"{name}.txt")
            if os.path.exists(label_path):
                valid_images.append(img)
        
        if len(valid_images) == 0:
            raise ValueError("Не найдено изображений с разметкой!")
        
        print(f"📊 Всего изображений с разметкой: {len(valid_images)}")
        
        # Разделяем
        from sklearn.model_selection import train_test_split
        
        train_images, temp_images = train_test_split(
            valid_images, train_size=train_ratio, random_state=42
        )
        
        val_ratio_adjusted = val_ratio / (val_ratio + test_ratio)
        val_images, test_images = train_test_split(
            temp_images, train_size=val_ratio_adjusted, random_state=42
        )
        
        # Создаём структуру
        for split in ['train', 'val', 'test']:
            os.makedirs(os.path.join(output_dir, 'images', split), exist_ok=True)
            os.makedirs(os.path.join(output_dir, 'labels', split), exist_ok=True)
        
        # Копируем файлы
        def copy_files(image_list, split_name):
            for img in image_list:
                name = os.path.splitext(img)[0]
                shutil.copy2(
                    os.path.join(source_images_dir, img),
                    os.path.join(output_dir, 'images', split_name, img)
                )
                shutil.copy2(
                    os.path.join(source_labels_dir, f"{name}.txt"),
                    os.path.join(output_dir, 'labels', split_name, f"{name}.txt")
                )
        
        copy_files(train_images, 'train')
        copy_files(val_images, 'val')
        copy_files(test_images, 'test')
        
        print(f"✅ Разделение завершено!")
        print(f"   Train: {len(train_images)} изображений")
        print(f"   Val:   {len(val_images)} изображений")
        print(f"   Test:  {len(test_images)} изображений")
        
        return {
            'train': len(train_images),
            'val': len(val_images),
            'test': len(test_images),
            'output_dir': output_dir
        }


