    def start_training(self):
        """Запуск обучения YOLO"""
        if not YOLO_AVAILABLE:
            QMessageBox.warning(self, 'Ошибка', 'Ultralytics не установлен. Выполните: pip install ultralytics')
            return
        
        images_dir = self.images_dir.text()
        labels_dir = self.labels_dir.text()
        
        if not images_dir or not labels_dir:
            QMessageBox.warning(self, 'Ошибка', 'Укажите пути к изображениям и разметке')
            return
        
        # Проверяем наличие YAML файла
        yaml_path = "leaf_dataset.yaml"
        if not os.path.exists(yaml_path):
            # Создаем YAML файл
            yaml_content = f"""
path: ./dataset_yolo
train: images/train
val: images/val
test: images/test

nc: 2
names: ['leaf', 'damage']
"""
            with open(yaml_path, 'w') as f:
                f.write(yaml_content)
            self.train_log.append(f"📄 Создан конфиг: {yaml_path}")
        
        # Запускаем обучение в отдельном потоке
        self.train_thread = QThread()
        self.train_worker = TrainingWorker(images_dir, labels_dir, self.epochs_spin.value())
        self.train_worker.moveToThread(self.train_thread)
        self.train_worker.progress.connect(self.on_training_progress)
        self.train_worker.finished.connect(self.on_training_finished)
        self.train_worker.error.connect(self.on_training_error)
        self.train_thread.started.connect(self.train_worker.run)
        self.train_thread.start()
        
        self.train_btn.setEnabled(False)
        self.train_log.append("🚀 Запуск обучения YOLO...")
        self.status_bar.showMessage('🔄 Обучение YOLO...')
    
    def on_training_progress(self, message):
        """Обновление прогресса обучения"""
        self.train_log.append(message)
        # Автопрокрутка вниз
        scrollbar = self.train_log.verticalScrollBar()
        scrollbar.setValue(scrollbar.maximum())
        QApplication.processEvents()
    
    def on_training_finished(self, model_path):
        """Обучение завершено"""
        self.train_btn.setEnabled(True)
        self.train_log.append(f"\n✅ Обучение завершено!")
        self.train_log.append(f"📁 Модель сохранена: {model_path}")
        self.status_bar.showMessage(f'✅ Обучение завершено: {model_path}')
        
        # Обновляем анализатор
        self.yolo_checkbox.setChecked(True)
        QMessageBox.information(self, 'Обучение', f'Обучение завершено!\nМодель: {model_path}')
    
    def on_training_error(self, error_msg):
        """Ошибка при обучении"""
        self.train_btn.setEnabled(True)
        self.train_log.append(f"\n❌ Ошибка: {error_msg}")
        self.status_bar.showMessage('❌ Ошибка обучения')
        QMessageBox.critical(self, 'Ошибка', error_msg)


