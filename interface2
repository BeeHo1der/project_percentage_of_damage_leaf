        damaged_pct = self.results.get('damaged_percent', 0.0)
        
        text = [
            "🍃 РЕЗУЛЬТАТЫ АНАЛИЗА",
            "=" * 35,
            f"📊 Листьев: {leaves}",
            f"📐 Общая площадь: {total:.1f} см²",
            f"🟢 Здоровая площадь: {healthy:.1f} см² ({healthy_pct:.1f}%)",
            f"🔴 Поврежденная площадь: {damaged:.1f} см² ({damaged_pct:.1f}%)",
            f"⚠️ Общий процент поражения: {damaged_pct:.1f}%"
        ]
        
        if leaves > 0:
            text.append("")
            text.append("📊 ПО ЛИСТЬЯМ:")
            for i, leaf in enumerate(self.results.get('leaves', [])):
                text.append(f"  Лист {i+1}: {leaf['total_area_cm']:.1f}см², "
                          f"Зд:{leaf['healthy_percent']:.0f}%, "
                          f"Пов:{leaf['damaged_percent']:.0f}%")
        
        self.results_text.setText('\n'.join(text))
    
    def add_to_history(self):
        filename = os.path.basename(self.current_image_path)
        date = datetime.now().strftime("%d.%m.%Y %H:%M")
        
        pixmap = QPixmap(self.current_image_path)
        icon = QIcon() if pixmap.isNull() else QIcon(QPixmap.fromImage(pixmap.scaled(60, 60).toImage()))
        
        leaves = self.results.get('total_leaves', 0)
        damaged = self.results.get('damaged_percent', 0.0)
        text = f"{filename}\n📅 {date}\n🍃 {leaves} лист. | ⚠️ {damaged:.1f}%"
        
        item = QListWidgetItem()
        item.setText(text)
        item.setIcon(icon)
        item.setData(Qt.UserRole, {
            'filename': filename,
            'date': date,
            'image_path': self.current_image_path,
            'results': self.results
        })
        
        self.history_list.insertItem(0, item)
    
    def load_from_history(self, item):
        data = item.data(Qt.UserRole)
        if data:
            self.current_image_path = data['image_path']
            self.results = data['results']
            
            self.display_image(self.current_image_path, self.original_label)
            if 'visualization' in self.results:
                self.display_analysis_result(self.results['visualization'])
            if 'mask_viz' in self.results:
                self.display_mask(self.results['mask_viz'])
            self.display_results()
            
            self.file_info.setText(f'📁 {data["filename"]}\n📅 {data["date"]}')
            self.analyze_btn.setEnabled(True)
    
    def clear_history(self):
        reply = QMessageBox.question(self, 'Очистка', 'Очистить историю?',
                                   QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.history_list.clear()


def main():
    app = QApplication.instance()
    if app is None:
        app = QApplication(sys.argv)
    
    window = LeafDiseaseAnalyzerGUI()
    window.show()
    return app.exec_()


