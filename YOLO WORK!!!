    def load_yolo_model(self):
        if not YOLO_AVAILABLE:
            QMessageBox.warning(self, 'Warning', 
                'Ultralytics YOLO not installed.\nInstall with: pip install ultralytics')
            return
        
        file_path, _ = QFileDialog.getOpenFileName(
            self, 'Select YOLO model', os.path.expanduser("~"),
            'YOLO models (*.pt *.pth);;All files (*.*)'
        )
        
        if file_path:
            try:
                self.yolo_model_path = file_path
                model_name = os.path.basename(file_path)
                self.model_info.setText(f'Model loaded:\n{model_name}\nStatus: Ready')
                self.model_info.setStyleSheet('padding: 10px; background-color: #f8f9fa; border-radius: 5px; color: #27ae60;')
                self.status_bar.showMessage(f'YOLO model loaded: {model_name}')
            except Exception as e:
                QMessageBox.critical(self, 'Error', f'Failed to load model:\n{str(e)}')
    
    def load_image(self):
        file_path, _ = QFileDialog.getOpenFileName(
            self, 'Select image', os.path.expanduser("~"),
            'Images (*.png *.jpg *.jpeg *.bmp *.tiff);;All files (*.*)'
        )
        
        if file_path:
            try:
                test_img = cv2.imread(file_path)
                if test_img is None:
                    QMessageBox.critical(self, 'Error', 'Failed to load image')
                    return
                
                self.current_image_path = file_path
                self.display_image(file_path, self.original_label)
                
                file_name = os.path.basename(file_path)
                file_size = os.path.getsize(file_path) / 1024
                file_size_str = f"{file_size:.1f} KB" if file_size < 1024 else f"{file_size/1024:.2f} MB"
                
                self.file_info.setText(f'{file_name}\n{file_size_str}')
                self.analyze_btn.setEnabled(True)
                self.export_btn.setEnabled(False)
                self.status_bar.showMessage(f'Loaded: {file_name}')
                
            except Exception as e:
                QMessageBox.critical(self, 'Error', f'Error: {str(e)}')
    
    def display_image(self, image_path, label_widget):
        try:
            pixmap = QPixmap(image_path)
            if not pixmap.isNull():
                scaled = pixmap.scaled(800, 600, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                label_widget.setPixmap(scaled)
                label_widget.setText("")
        except:
            label_widget.setText("Failed to load image")
    
    def display_mask(self, mask_img):
        try:
            if mask_img is not None:
                rgb = cv2.cvtColor(mask_img, cv2.COLOR_BGR2RGB)
                h, w, ch = rgb.shape
                qt_img = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
                pixmap = QPixmap.fromImage(qt_img)
                scaled = pixmap.scaled(800, 600, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                self.mask_label.setPixmap(scaled)
                self.mask_label.setText("")
        except:
            self.mask_label.setText("Failed to display mask")
    
    def analyze(self):
        if not self.current_image_path:
            return
        
        try:
            self.progress.show()
            self.progress.setValue(0)
            self.status_bar.showMessage('Analyzing...')
            
            self.analyzer = LeafDiseaseAnalyzer(
                pixels_per_cm=self.ppc_spin.value(),
                min_leaf_area_cm=self.min_area_spin.value(),
                yolo_model_path=self.yolo_model_path
            )
            
            self.progress.setValue(30)
            QApplication.processEvents()
            
            self.results = self.analyzer.analyze_image(self.current_image_path)
            
            self.progress.setValue(80)
            QApplication.processEvents()
            
            if 'visualization' in self.results:
                self.display_analysis_result(self.results['visualization'])
            
            if 'mask_viz' in self.results:
                self.display_mask(self.results['mask_viz'])
            
            if 'debug_info' in self.results:
                self.debug_text.setText(self.results['debug_info'])
            
            self.update_tables()
            self.export_btn.setEnabled(True)
            
            self.progress.setValue(100)
            self.status_bar.showMessage('Analysis complete')
            
        except Exception as e:
            QMessageBox.critical(self, 'Error', f'Analysis error:\n{str(e)}')
            self.debug_text.setText(f"ERROR: {str(e)}")
        finally:
            self.progress.hide()
    
    def display_analysis_result(self, vis_img):
        try:
            rgb = cv2.cvtColor(vis_img, cv2.COLOR_BGR2RGB)
            h, w, ch = rgb.shape
            qt_img = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
            pixmap = QPixmap.fromImage(qt_img)
            scaled = pixmap.scaled(800, 600, Qt.KeepAspectRatio, Qt.SmoothTransformation)
            self.result_label.setPixmap(scaled)
            self.result_label.setText("")
        except:
            self.result_label.setText("Failed to display result")
    
    def update_tables(self):
        if not self.results:
            return
        
        leaves = self.results.get('leaves', [])
        self.leaves_table.setRowCount(len(leaves))
        
        for i, leaf in enumerate(leaves):
            item_num = QTableWidgetItem(str(i + 1))
            item_num.setTextAlignment(Qt.AlignCenter)
            self.leaves_table.setItem(i, 0, item_num)
            
            item_area = QTableWidgetItem(f"{leaf['total_area_cm']:.2f}")
            item_area.setTextAlignment(Qt.AlignCenter)
            self.leaves_table.setItem(i, 1, item_area)
            
            item_health = QTableWidgetItem(f"{leaf['healthy_percent']:.1f}%")
            item_health.setTextAlignment(Qt.AlignCenter)
            if leaf['healthy_percent'] > 70:
                item_health.setForeground(QBrush(QColor(39, 174, 96)))
            elif leaf['healthy_percent'] > 40:
                item_health.setForeground(QBrush(QColor(241, 196, 15)))
            else:
                item_health.setForeground(QBrush(QColor(231, 76, 60)))
            self.leaves_table.setItem(i, 2, item_health)
            
            item_damage = QTableWidgetItem(f"{leaf['damaged_percent']:.1f}%")
            item_damage.setTextAlignment(Qt.AlignCenter)
            if leaf['damaged_percent'] < 30:
                item_damage.setForeground(QBrush(QColor(39, 174, 96)))
            elif leaf['damaged_percent'] < 60:
                item_damage.setForeground(QBrush(QColor(241, 196, 15)))
            else:
                item_damage.setForeground(QBrush(QColor(231, 76, 60)))
            self.leaves_table.setItem(i, 3, item_damage)
            
            status_text = "Healthy" if leaf['damaged_percent'] < 30 else "Damaged" if leaf['damaged_percent'] < 60 else "Critical"
            item_status = QTableWidgetItem(status_text)
            item_status.setTextAlignment(Qt.AlignCenter)
            self.leaves_table.setItem(i, 4, item_status)
        
        self.leaves_table.resizeColumnsToContents()
        
        summary_data = [
            ('Total leaves', f"{self.results.get('total_leaves', 0)}"),
            ('Total area', f"{self.results.get('total_area_cm', 0):.2f} cm2"),
            ('Healthy area', f"{self.results.get('total_healthy_cm', 0):.2f} cm2"),
            ('Damaged area', f"{self.results.get('total_damaged_cm', 0):.2f} cm2"),
            ('Overall health', f"{self.results.get('healthy_percent', 0):.1f}%"),
            ('Overall damage', f"{self.results.get('damaged_percent', 0):.1f}%")
        ]
        
        self.summary_table.setRowCount(len(summary_data))
        for i, (param, value) in enumerate(summary_data):
            item_param = QTableWidgetItem(param)
            item_param.setFont(QFont('Arial', 10, QFont.Bold))
            self.summary_table.setItem(i, 0, item_param)
            
            item_value = QTableWidgetItem(value)
            item_value.setTextAlignment(Qt.AlignRight)
            self.summary_table.setItem(i, 1, item_value)
        
        self.summary_table.resizeColumnsToContents()
        
        health_percent = self.results.get('healthy_percent', 0)
        self.health_progress.setValue(int(health_percent))
        
        if health_percent > 70:
            self.health_progress.setStyleSheet('''
                QProgressBar::chunk { background-color: #27ae60; }
                QProgressBar { text-align: center; }
            ''')
        elif health_percent > 40:
            self.health_progress.setStyleSheet('''
                QProgressBar::chunk { background-color: #f39c12; }
                QProgressBar { text-align: center; }
            ''')
        else:
            self.health_progress.setStyleSheet('''
                QProgressBar::chunk { background-color: #e74c3c; }
                QProgressBar { text-align: center; }
            ''')
    
    def export_results(self):
        if not self.results:
            QMessageBox.warning(self, 'Warning', 'No results to export')
            return
        
        file_path, _ = QFileDialog.getSaveFileName(
            self, 'Save results', 
            f"analysis_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv",
            'CSV files (*.csv);;All files (*.*)'
        )
        
        if file_path:
            try:
                with open(file_path, 'w', newline='', encoding='utf-8') as csvfile:
                    writer = csv.writer(csvfile)
                    
                    writer.writerow(['LEAF ANALYSIS RESULTS'])
                    writer.writerow(['Date:', datetime.now().strftime('%Y-%m-%d %H:%M:%S')])
                    writer.writerow(['File:', os.path.basename(self.current_image_path)])
                    writer.writerow([])
                    
                    writer.writerow(['SUMMARY DATA'])
                    writer.writerow(['Parameter', 'Value'])
                    writer.writerow(['Total leaves', self.results.get('total_leaves', 0)])
                    writer.writerow(['Total area (cm2)', f"{self.results.get('total_area_cm', 0):.2f}"])
                    writer.writerow(['Healthy area (cm2)', f"{self.results.get('total_healthy_cm', 0):.2f}"])
                    writer.writerow(['Damaged area (cm2)', f"{self.results.get('total_damaged_cm', 0):.2f}"])
                    writer.writerow(['Overall health (%)', f"{self.results.get('healthy_percent', 0):.1f}"])
                    writer.writerow(['Overall damage (%)', f"{self.results.get('damaged_percent', 0):.1f}"])
                    writer.writerow([])
                    
                    writer.writerow(['DETAILED LEAF ANALYSIS'])
                    writer.writerow(['Leaf', 'Area (cm2)', 'Health (%)', 'Damage (%)', 'Status'])
                    
                    for i, leaf in enumerate(self.results.get('leaves', [])):
                        status = "Healthy" if leaf['damaged_percent'] < 30 else "Damaged" if leaf['damaged_percent'] < 60 else "Critical"
                        writer.writerow([
                            i + 1,
                            f"{leaf['total_area_cm']:.2f}",
                            f"{leaf['healthy_percent']:.1f}",
                            f"{leaf['damaged_percent']:.1f}",
                            status
                        ])
                
                QMessageBox.information(self, 'Success', f'Results saved to:\n{file_path}')
                self.status_bar.showMessage('Results exported to CSV')
                
            except Exception as e:
                QMessageBox.critical(self, 'Error', f'Failed to save file:\n{str(e)}')


