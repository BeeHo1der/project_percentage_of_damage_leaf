class LeafDiseaseAnalyzer:
    def __init__(self, pixels_per_cm: float = 62.0, min_leaf_area_cm: float = 1.0, 
                 yolo_model_path: str = None):
        self.pixels_per_cm = pixels_per_cm
        self.min_leaf_area_cm = min_leaf_area_cm
        
        # Инициализация YOLO модели
        self.yolo_model = None
        if YOLO_AVAILABLE and yolo_model_path and os.path.exists(yolo_model_path):
            try:
                self.yolo_model = YOLO(yolo_model_path)
                print(f"YOLO model loaded from {yolo_model_path}")
            except Exception as e:
                print(f"Failed to load YOLO model: {e}")
        
        # Улучшенные диапазоны для здоровых зеленых листьев
        self.healthy_ranges = {
            'green_bright': {'lower': [40, 40, 40], 'upper': [80, 255, 255]},
            'green_dark': {'lower': [35, 30, 30], 'upper': [75, 255, 200]},
            'green_light': {'lower': [30, 35, 50], 'upper': [85, 255, 255]},
            'green_yellowish': {'lower': [25, 40, 40], 'upper': [35, 255, 255]},
        }
        
        # Улучшенные диапазоны для повреждений
        self.damage_ranges = {
            'brown_dark': {'lower': [0, 20, 20], 'upper': [15, 255, 100]},
            'brown_light': {'lower': [5, 30, 60], 'upper': [20, 200, 150]},
            'yellow_brown': {'lower': [15, 50, 80], 'upper': [25, 255, 200]},
            'necrotic_black': {'lower': [0, 0, 0], 'upper': [180, 30, 40]},
            'dry_white': {'lower': [0, 0, 180], 'upper': [180, 30, 255]},
            'rust_orange': {'lower': [5, 100, 100], 'upper': [20, 255, 200]},
        }
        
        # Диапазоны для сомнительных участков
        self.uncertain_ranges = {
            'yellowing': {'lower': [20, 40, 80], 'upper': [30, 200, 200]},
            'pale_green': {'lower': [25, 20, 60], 'upper': [35, 100, 180]},
        }
        
        # Маппинг классов YOLO (из data.yaml)
        self.yolo_classes = {
            0: 'erozia',      # Эрозия/повреждения
            1: 'leaf',        # Лист
            2: 'list'         # Лист (альтернативное название)
        }

    def detect_leaves_with_yolo(self, img: np.ndarray) -> List[np.ndarray]:
        """Обнаружение листьев с помощью YOLO"""
        if self.yolo_model is None:
            return []
        
        try:
            # Запуск инференса
            results = self.yolo_model(img, verbose=False)
            
            leaf_contours = []
            
            for result in results:
                if result.boxes is not None:
                    for box in result.boxes:
                        # Получаем класс объекта
                        class_id = int(box.cls[0])
                        class_name = self.yolo_classes.get(class_id, 'unknown')
                        
                        # Нас интересуют только листья (классы 1 и 2)
                        if class_name in ['leaf', 'list']:
                            # Получаем координаты bounding box
                            x1, y1, x2, y2 = map(int, box.xyxy[0])
                            
                            # Создаем контур из bounding box
                            contour = np.array([
                                [x1, y1],
                                [x2, y1],
                                [x2, y2],
                                [x1, y2]
                            ], dtype=np.int32)
                            
                            # Уточняем контур с помощью сегментации
                            refined_contour = self.refine_contour_with_mask(img, contour)
                            leaf_contours.append(refined_contour)
            
            return leaf_contours
            
        except Exception as e:
            print(f"YOLO detection error: {e}")
            return []

    def refine_contour_with_mask(self, img: np.ndarray, bbox_contour: np.ndarray) -> np.ndarray:
        """Уточнение контура листа внутри bounding box с использованием GrabCut"""
        x, y, w, h = cv2.boundingRect(bbox_contour)
        
        # Добавляем небольшой отступ
        margin = 10
        x = max(0, x - margin)
        y = max(0, y - margin)
        w = min(img.shape[1] - x, w + 2 * margin)
        h = min(img.shape[0] - y, h + 2 * margin)
        
        # Применяем GrabCut для точного выделения
        mask = np.zeros(img.shape[:2], np.uint8)
        bgd_model = np.zeros((1, 65), np.float64)
        fgd_model = np.zeros((1, 65), np.float64)
        
        rect = (x, y, w, h)
        
        try:
            cv2.grabCut(img, mask, rect, bgd_model, fgd_model, 5, cv2.GC_INIT_WITH_RECT)
            
            # Создаем маску
            refined_mask = np.where((mask == cv2.GC_FGD) | (mask == cv2.GC_PR_FGD), 255, 0).astype(np.uint8)
            
            # Находим контуры
            contours, _ = cv2.findContours(refined_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
            
            if contours:
                # Берем самый большой контур
                largest = max(contours, key=cv2.contourArea)
                # Сглаживаем
                peri = cv2.arcLength(largest, True)
                epsilon = 0.005 * peri
                return cv2.approxPolyDP(largest, epsilon, True)
        except:
            pass
        
        return bbox_contour

    def preprocess_image(self, image_path: str) -> Tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
        """Предобработка изображения"""
        img = cv2.imread(image_path)
        if img is None:
            raise FileNotFoundError(f"Не удалось загрузить изображение: {image_path}")
        
        original_height, original_width = img.shape[:2]
        
        if original_width > 1200:
            self.scale_factor = 1200 / original_width
            new_size = (int(original_width * self.scale_factor), 
                       int(original_height * self.scale_factor))
            img = cv2.resize(img, new_size)
        else:
            self.scale_factor = 1.0
        
        original = img.copy()
        
        # Улучшенная предобработка
        img = cv2.bilateralFilter(img, 9, 75, 75)
        
        # Конвертируем в разные цветовые пространства
        hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
        lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
        ycrcb = cv2.cvtColor(img, cv2.COLOR_BGR2YCrCb)
        
        return original, hsv, lab, ycrcb

    def detect_leaf_contours_robust(self, img: np.ndarray, hsv: np.ndarray) -> List[np.ndarray]:
        """Улучшенное обнаружение контуров листьев с использованием YOLO"""
        
        leaf_contours = []
        
        # Метод 1: Используем YOLO если доступен
        if self.yolo_model is not None:
            yolo_contours = self.detect_leaves_with_yolo(img)
            if yolo_contours:
                leaf_contours.extend(yolo_contours)
                print(f"YOLO detected {len(yolo_contours)} leaves")
        
        # Метод 2: Традиционные методы компьютерного зрения (как fallback или дополнение)
        # Сегментация по цвету
        green_mask = self.create_vegetation_mask(hsv)
        
        # Edge detection
        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
        median = np.median(gray)
        lower = int(max(0, (0.5 * median)))
        upper = int(min(255, (1.5 * median)))
        edges = cv2.Canny(gray, lower, upper)
        
        kernel = np.ones((3, 3), np.uint8)
        edges = cv2.dilate(edges, kernel, iterations=2)
        
        # Адаптивная пороговая обработка
        blurred = cv2.GaussianBlur(gray, (5, 5), 0)
        adaptive_thresh = cv2.adaptiveThreshold(blurred, 255, 
                                                  cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
                                                  cv2.THRESH_BINARY_INV, 11, 2)
        
        # Комбинируем маски
        combined_mask = cv2.bitwise_or(green_mask, edges)
        combined_mask = cv2.bitwise_or(combined_mask, adaptive_thresh)
        
        # Морфологические операции
        kernel_large = np.ones((15, 15), np.uint8)
        combined_mask = cv2.morphologyEx(combined_mask, cv2.MORPH_CLOSE, kernel_large, iterations=3)
        combined_mask = cv2.morphologyEx(combined_mask, cv2.MORPH_OPEN, kernel_large, iterations=2)
        
        # Находим контуры
        contours, _ = cv2.findContours(combined_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        
        # Фильтруем контуры по площади
        min_area_px = self.min_leaf_area_cm * (self.pixels_per_cm ** 2)
        
        for contour in contours:
            area = cv2.contourArea(contour)
            if area > min_area_px:
                # Проверяем, не дублирует ли этот контур уже найденный YOLO
                is_duplicate = False
                for existing in leaf_contours:
                    existing_area = cv2.contourArea(existing)
                    if abs(area - existing_area) / max(area, existing_area) < 0.3:
                        # Проверяем перекрытие
                        rect1 = cv2.boundingRect(contour)
                        rect2 = cv2.boundingRect(existing)
                        if self.rectangles_overlap(rect1, rect2, 0.5):
                            is_duplicate = True
                            break
                
                if not is_duplicate:
                    peri = cv2.arcLength(contour, True)
                    epsilon = 0.005 * peri
                    approx = cv2.approxPolyDP(contour, epsilon, True)
                    leaf_contours.append(approx)
        
        return leaf_contours
    
    def rectangles_overlap(self, rect1, rect2, threshold=0.5):
        """Проверка перекрытия двух прямоугольников"""
        x1, y1, w1, h1 = rect1
        x2, y2, w2, h2 = rect2
        
        # Вычисляем пересечение
        x_overlap = max(0, min(x1 + w1, x2 + w2) - max(x1, x2))
        y_overlap = max(0, min(y1 + h1, y2 + h2) - max(y1, y2))
        overlap_area = x_overlap * y_overlap
        
        area1 = w1 * h1
        area2 = w2 * h2
        
        overlap_ratio = overlap_area / min(area1, area2)
        return overlap_ratio > threshold

    def create_vegetation_mask(self, hsv: np.ndarray) -> np.ndarray:
        """Создание маски для растительности"""
        vegetation_mask = np.zeros(hsv.shape[:2], dtype=np.uint8)
        
        for range_dict in self.healthy_ranges.values():
            lower = np.array(range_dict['lower'])
            upper = np.array(range_dict['upper'])
            mask = cv2.inRange(hsv, lower, upper)
            vegetation_mask = cv2.bitwise_or(vegetation_mask, mask)
        
        kernel = np.ones((5, 5), np.uint8)
        vegetation_mask = cv2.morphologyEx(vegetation_mask, cv2.MORPH_CLOSE, kernel, iterations=2)
        vegetation_mask = cv2.morphologyEx(vegetation_mask, cv2.MORPH_OPEN, kernel, iterations=1)
        
        return vegetation_mask

    def analyze_texture(self, img: np.ndarray, mask: np.ndarray, x: int, y: int, window_size: int = 15) -> float:
        """Анализ текстуры для определения здоровья ткани"""
        half = window_size // 2
        x_start = max(0, x - half)
        x_end = min(img.shape[1], x + half)
        y_start = max(0, y - half)
        y_end = min(img.shape[0], y + half)
        
        roi = img[y_start:y_end, x_start:x_end]
        if roi.size == 0:
            return 0.5
        
        gray_roi = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)
        std_dev = np.std(gray_roi)
        
        # Частотный анализ
        f_transform = np.fft.fft2(gray_roi)
        f_shift = np.fft.fftshift(f_transform)
        magnitude = np.abs(f_shift)
        
        rows, cols = magnitude.shape
        crow, ccol = rows // 2, cols // 2
        high_freq = magnitude[crow-3:crow+3, ccol-3:ccol+3]
        high_freq_energy = np.sum(high_freq**2)
        
        total_energy = np.sum(magnitude**2)
        high_freq_ratio = high_freq_energy / (total_energy + 1e-6)
        
        texture_health = min(1.0, high_freq_ratio * 10)
        
        return texture_health

    def classify_pixel_advanced(self, hsv_pixel: np.ndarray, lab_pixel: np.ndarray, 
                                ycrcb_pixel: np.ndarray, texture_health: float) -> Tuple[str, float]:
        """Продвинутая классификация пикселя"""
        
        for range_dict in self.healthy_ranges.values():
            lower = np.array(range_dict['lower'])
            upper = np.array(range_dict['upper'])
            if (hsv_pixel[0] >= lower[0] and hsv_pixel[0] <= upper[0] and
                hsv_pixel[1] >= lower[1] and hsv_pixel[1] <= upper[1] and
                hsv_pixel[2] >= lower[2] and hsv_pixel[2] <= upper[2]):
                if lab_pixel[1] > 120 and lab_pixel[2] < 135:
                    return 'healthy', 1.0
        
        for damage_name, range_dict in self.damage_ranges.items():
            lower = np.array(range_dict['lower'])
            upper = np.array(range_dict['upper'])
            if (hsv_pixel[0] >= lower[0] and hsv_pixel[0] <= upper[0] and
                hsv_pixel[1] >= lower[1] and hsv_pixel[1] <= upper[1] and
                hsv_pixel[2] >= lower[2] and hsv_pixel[2] <= upper[2]):
                return 'damaged', 0.95
        
        for range_dict in self.uncertain_ranges.values():
            lower = np.array(range_dict['lower'])
            upper = np.array(range_dict['upper'])
            if (hsv_pixel[0] >= lower[0] and hsv_pixel[0] <= upper[0] and
                hsv_pixel[1] >= lower[1] and hsv_pixel[1] <= upper[1] and
                hsv_pixel[2] >= lower[2] and hsv_pixel[2] <= upper[2]):
                if texture_health > 0.4:
                    return 'healthy', 0.7
                else:
                    return 'damaged', 0.6
        
        if ycrcb_pixel[1] < 130 and ycrcb_pixel[2] > 140:
            if texture_health < 0.3:
                return 'damaged', 0.7
        
        if texture_health > 0.6:
            return 'healthy', 0.6
        elif texture_health < 0.3:
            return 'damaged', 0.6
        else:
            return 'uncertain', 0.5

    def analyze_leaf_detailed(self, contour: np.ndarray, 
                             original_img: np.ndarray,
                             hsv_img: np.ndarray,
                             lab_img: np.ndarray,
                             ycrcb_img: np.ndarray) -> Dict:
        """Детальный анализ листа"""
        
        leaf_mask = np.zeros(hsv_img.shape[:2], dtype=np.uint8)
        cv2.drawContours(leaf_mask, [contour], -1, 255, -1)
        
        total_area_px = cv2.contourArea(contour)
        total_area_cm = total_area_px / (self.pixels_per_cm ** 2)
        
        healthy_mask = np.zeros_like(leaf_mask)
        damage_mask = np.zeros_like(leaf_mask)
        uncertain_mask = np.zeros_like(leaf_mask)
        
        healthy_pixels = 0
        damaged_pixels = 0
        
        for y in range(leaf_mask.shape[0]):
            for x in range(leaf_mask.shape[1]):
                if leaf_mask[y, x] > 0:
                    hsv_pixel = hsv_img[y, x]
                    lab_pixel = lab_img[y, x]
                    ycrcb_pixel = ycrcb_img[y, x]
                    
                    texture_health = self.analyze_texture(original_img, leaf_mask, x, y)
                    
                    classification, confidence = self.classify_pixel_advanced(
                        hsv_pixel, lab_pixel, ycrcb_pixel, texture_health
                    )
                    
                    if classification == 'healthy':
                        healthy_mask[y, x] = 255
                        healthy_pixels += 1
                    elif classification == 'damaged':
                        damage_mask[y, x] = 255
                        damaged_pixels += 1
                    else:
                        uncertain_mask[y, x] = 128
        
        kernel = np.ones((3, 3), np.uint8)
        damage_mask = cv2.morphologyEx(damage_mask, cv2.MORPH_OPEN, kernel, iterations=1)
        damage_mask = cv2.morphologyEx(damage_mask, cv2.MORPH_CLOSE, kernel, iterations=2)
        
        damaged_pixels = cv2.countNonZero(damage_mask)
        healthy_pixels = cv2.countNonZero(healthy_mask)
        
        for y in range(uncertain_mask.shape[0]):
            for x in range(uncertain_mask.shape[1]):
                if uncertain_mask[y, x] == 128:
                    y_start = max(0, y-2)
                    y_end = min(uncertain_mask.shape[0], y+3)
                    x_start = max(0, x-2)
                    x_end = min(uncertain_mask.shape[1], x+3)
                    
                    neighborhood_healthy = healthy_mask[y_start:y_end, x_start:x_end]
                    neighborhood_damage = damage_mask[y_start:y_end, x_start:x_end]
                    
                    healthy_neighbors = np.sum(neighborhood_healthy > 0)
                    damage_neighbors = np.sum(neighborhood_damage > 0)
                    
                    if healthy_neighbors > damage_neighbors:
                        healthy_mask[y, x] = 255
                        healthy_pixels += 1
                    elif damage_neighbors > healthy_neighbors:
                        damage_mask[y, x] = 255
                        damaged_pixels += 1
                    else:
                        texture = self.analyze_texture(original_img, leaf_mask, x, y, 7)
                        if texture > 0.4:
                            healthy_mask[y, x] = 255
                            healthy_pixels += 1
                        else:
                            damage_mask[y, x] = 255
                            damaged_pixels += 1
        
        healthy_area_cm = healthy_pixels / (self.pixels_per_cm ** 2)
        damaged_area_cm = damaged_pixels / (self.pixels_per_cm ** 2)
        
        if total_area_px > 0:
            healthy_percent = (healthy_pixels / total_area_px) * 100
            damaged_percent = (damaged_pixels / total_area_px) * 100
        else:
            healthy_percent = 0
            damaged_percent = 0
        
        return {
            'total_area_cm': total_area_cm,
            'healthy_area_cm': healthy_area_cm,
            'damaged_area_cm': damaged_area_cm,
            'healthy_percent': min(100.0, healthy_percent),
            'damaged_percent': min(100.0, damaged_percent),
            'leaf_mask': leaf_mask,
            'healthy_mask': healthy_mask,
            'damage_mask': damage_mask,
            'contour': contour
        }

    def analyze_image(self, image_path: str) -> Dict:
        """Полный анализ изображения"""
        try:
            original, hsv, lab, ycrcb = self.preprocess_image(image_path)
            
            leaf_contours = self.detect_leaf_contours_robust(original, hsv)
            
            mask_viz = np.zeros((original.shape[0], original.shape[1], 3), dtype=np.uint8)
            
            results_list = []
            total_healthy = 0
            total_damaged = 0
            total_area = 0
            debug_info = []
            
            detection_method = "YOLO + CV" if self.yolo_model else "Computer Vision only"
            debug_info.append(f"Detection method: {detection_method}")
            
            for i, contour in enumerate(leaf_contours):
                area_px = cv2.contourArea(contour)
                area_cm = area_px / (self.pixels_per_cm ** 2)
                
                leaf_result = self.analyze_leaf_detailed(contour, original, hsv, lab, ycrcb)
                results_list.append(leaf_result)
                total_healthy += leaf_result['healthy_area_cm']
                total_damaged += leaf_result['damaged_area_cm']
                total_area += leaf_result['total_area_cm']
                
                debug_info.append(f"Leaf {i+1}: {area_cm:.2f} cm2, "
                                f"Health: {leaf_result['healthy_percent']:.1f}%, "
                                f"Damage: {leaf_result['damaged_percent']:.1f}%")
                
                mask_viz[leaf_result['healthy_mask'] > 0] = [0, 255, 0]
                mask_viz[leaf_result['damage_mask'] > 0] = [0, 0, 255]
            
            if total_area > 0:
                overall_healthy = (total_healthy / total_area) * 100
                overall_damaged = (total_damaged / total_area) * 100
            else:
                overall_healthy = 0
                overall_damaged = 0
            
            visualization = self.create_visualization(original, results_list)
            
            debug_text = "LEAF ANALYSIS DEBUG\n" + "="*50 + "\n"
            debug_text += f"Detection: {detection_method}\n"
            debug_text += f"YOLO available: {self.yolo_model is not None}\n"
            debug_text += f"Leaves detected: {len(results_list)}\n\n"
            for line in debug_info:
                debug_text += f"  {line}\n"
            debug_text += f"\nTotal area: {total_area:.2f} cm2\n"
            debug_text += f"Overall health: {overall_healthy:.1f}%\n"
            debug_text += f"Overall damage: {overall_damaged:.1f}%"
            
            return {
                'total_leaves': len(results_list),
                'leaves': results_list,
                'total_area_cm': total_area,
                'total_healthy_cm': total_healthy,
                'total_damaged_cm': total_damaged,
                'healthy_percent': overall_healthy,
                'damaged_percent': overall_damaged,
                'debug_info': debug_text,
                'visualization': visualization,
                'mask_viz': mask_viz
            }
            
        except Exception as e:
            print(f"Error: {e}")
            import traceback
            traceback.print_exc()
            raise

    def create_visualization(self, img: np.ndarray, results: List) -> np.ndarray:
        """Визуализация результатов"""
        vis = img.copy()
        
        healthy_overlay = np.zeros_like(vis)
        damaged_overlay = np.zeros_like(vis)
        
        for i, result in enumerate(results):
            if 'healthy_mask' in result:
                healthy_overlay[result['healthy_mask'] > 0] = [0, 255, 0]
            
            if 'damage_mask' in result:
                damaged_overlay[result['damage_mask'] > 0] = [0, 0, 255]
            
            if 'contour' in result:
                cv2.drawContours(vis, [result['contour']], -1, (255, 255, 0), 3)
                
                M = cv2.moments(result['contour'])
                if M['m00'] != 0:
                    cx = int(M['m10'] / M['m00'])
                    cy = int(M['m01'] / M['m00'])
                    
                    cv2.rectangle(vis, (cx-120, cy-60), (cx+120, cy+40), (0, 0, 0), -1)
                    
                    text1 = f"Leaf {i+1}: {result['total_area_cm']:.1f} cm2"
                    text2 = f"Healthy: {result['healthy_percent']:.1f}% | Damage: {result['damaged_percent']:.1f}%"
                    
                    cv2.putText(vis, text1, (cx-115, cy-40),
                               cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 1)
                    cv2.putText(vis, text2, (cx-115, cy-20),
                               cv2.FONT_HERSHEY_SIMPLEX, 0.45, (255, 255, 255), 1)
                    
                    bar_width = 200
                    bar_height = 8
                    health_width = int(bar_width * result['healthy_percent'] / 100)
                    
                    cv2.rectangle(vis, (cx-115, cy), (cx-115+bar_width, cy+bar_height), (50, 50, 50), -1)
                    if health_width > 0:
                        cv2.rectangle(vis, (cx-115, cy), (cx-115+health_width, cy+bar_height), (0, 255, 0), -1)
        
        cv2.addWeighted(healthy_overlay, 0.3, vis, 1.0, 0, vis)
        cv2.addWeighted(damaged_overlay, 0.5, vis, 1.0, 0, vis)
        
        if results:
            total_health = sum(r['healthy_percent'] for r in results) / len(results)
            total_damage = sum(r['damaged_percent'] for r in results) / len(results)
            
            info = f"Leaves: {len(results)} | Health: {total_health:.1f}% | Damage: {total_damage:.1f}%"
            cv2.rectangle(vis, (10, 10), (500, 55), (0, 0, 0), -1)
            cv2.putText(vis, info, (15, 40), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)
            
            legend_y = vis.shape[0] - 30
            cv2.rectangle(vis, (10, legend_y-15), (330, legend_y+10), (0, 0, 0), -1)
            cv2.rectangle(vis, (15, legend_y-10), (35, legend_y+5), (0, 255, 0), -1)
            cv2.putText(vis, "Healthy", (40, legend_y), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 255, 255), 1)
            cv2.rectangle(vis, (110, legend_y-10), (130, legend_y+5), (0, 0, 255), -1)
            cv2.putText(vis, "Damaged", (135, legend_y), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 255, 255), 1)
            cv2.rectangle(vis, (210, legend_y-10), (230, legend_y+5), (255, 255, 0), -1)
            cv2.putText(vis, "Contour", (235, legend_y), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 255, 255), 1)
        
        return vis


