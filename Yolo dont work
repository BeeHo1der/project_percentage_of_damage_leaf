class TrainingWorker(QObject):
    progress = pyqtSignal(str)
    finished = pyqtSignal(str)
    error = pyqtSignal(str)
    
    def __init__(self, images_dir, labels_dir, epochs):
        super().__init__()
        self.images_dir = images_dir
        self.labels_dir = labels_dir
        self.epochs = epochs
    
    def run(self):
        try:
            self.progress.emit("📦 Подготовка датасета...")
            
            # Разделяем датасет
            output_dir = "dataset_yolo"
            DatasetSplitter.split_yolo_dataset(
                self.images_dir, self.labels_dir, output_dir,
                train_ratio=0.7, val_ratio=0.2, test_ratio=0.1
            )
            
            # Создаем YAML конфиг
            yaml_path = "leaf_dataset.yaml"
            yaml_content = f"""
path: ./{output_dir}
train: images/train
val: images/val
test: images/test

nc: 2
names: ['leaf', 'damage']
"""
            with open(yaml_path, 'w') as f:
                f.write(yaml_content)
            
            self.progress.emit("🚀 Загрузка модели YOLO...")
            
            # Загружаем модель
            model = YOLO("yolo26n.pt")
            
            self.progress.emit(f"🏋️ Начало обучения на {self.epochs} эпох...")
            
            # Обучение
            results = model.train(
                data=yaml_path,
                epochs=self.epochs,
                imgsz=640,
                batch=4,
                device="cpu",
                workers=0,
                patience=20,
                save=True,
                project="runs/yolo26",
                name="leaf_detection",
                exist_ok=True,
                verbose=False
            )
            
            model_path = "runs/yolo26/leaf_detection/weights/best.pt"
            self.progress.emit("✅ Модель сохранена!")
            self.finished.emit(model_path)
            
        except Exception as e:
            self.error.emit(str(e))


