class LeafDiseaseAnalyzer:
    """Анализатор листьев с поддержкой YOLO и классического CV"""
    
    def __init__(self, pixels_per_cm: float = 62.0, min_leaf_area_cm: float = 0.5,
                 use_yolo: bool = True, yolo_model_path: str = None):
        
        self.pixels_per_cm = pixels_per_cm
        self.min_leaf_area_cm = min_leaf_area_cm
        self.use_yolo = use_yolo and YOLO_AVAILABLE
        
        # Инициализация YOLO
        self.yolo = None
        if self.use_yolo:
            try:
                self.yolo = YOLODetector(yolo_model_path)
            except Exception as e:
                print(f"⚠️ YOLO не загружен: {e}")
                self.use_yolo = False
        
        # Диапазоны для здоровых листьев (зеленые оттенки)
        self.healthy_ranges = {
            'green_light': {'lower': [25, 20, 50], 'upper': [85, 255, 255]},
            'green_dark': {'lower': [25, 20, 20], 'upper': [95, 255, 180]},
            'green_yellowish': {'lower': [20, 20, 40], 'upper': [45, 255, 255]},
        }
        
        # Диапазоны для повреждений
        self.damage_ranges = {
            'yellow': {'lower': [15, 40, 100], 'upper': [35, 255, 255]},
            'brown_1': {'lower': [0, 30, 30], 'upper': [20, 255, 150]},
            'brown_2': {'lower': [160, 30, 30], 'upper': [180, 255, 150]},
            'white': {'lower': [0, 0, 200], 'upper': [180, 40, 255]},
            'necrotic': {'lower': [0, 0, 0], 'upper': [180, 255, 50]},
        }
    
    def preprocess_image(self, image_path: str) -> Tuple[np.ndarray, np.ndarray]:
        """Предобработка изображения"""
        img = cv2.imread(image_path)
        if img is None:
            raise FileNotFoundError(f"Не удалось загрузить изображение: {image_path}")
        
        # Изменяем размер для удобства
        height, width = img.shape[:2]
        if width > 1000:
            scale = 1000 / width
            new_size = (int(width * scale), int(height * scale))
            img = cv2.resize(img, new_size)
        
        original = img.copy()
        hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
        
        return original, hsv
    
    def create_mask(self, hsv: np.ndarray, ranges: Dict) -> np.ndarray:
        """Создание маски из нескольких диапазонов"""
        combined_mask = np.zeros(hsv.shape[:2], dtype=np.uint8)
        
        for name, range_dict in ranges.items():
            lower = np.array(range_dict['lower'])
            upper = np.array(range_dict['upper'])
            mask = cv2.inRange(hsv, lower, upper)
            combined_mask = cv2.bitwise_or(combined_mask, mask)
        
        # Морфологические операции
        kernel = np.ones((3, 3), np.uint8)
        combined_mask = cv2.morphologyEx(combined_mask, cv2.MORPH_OPEN, kernel)
        combined_mask = cv2.morphologyEx(combined_mask, cv2.MORPH_CLOSE, kernel)
        
        return combined_mask
    
    def find_leaves_by_color(self, mask: np.ndarray) -> List[Tuple[np.ndarray, float, float]]:
        """Поиск листьев по цветовой маске (классический метод)"""
        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        
        leaf_info = []
        for contour in contours:
            area_px = cv2.contourArea(contour)
            area_cm = area_px / (self.pixels_per_cm ** 2)
            
            if area_cm >= self.min_leaf_area_cm:
                epsilon = 0.01 * cv2.arcLength(contour, True)
                approx = cv2.approxPolyDP(contour, epsilon, True)
                leaf_info.append((approx, area_px, area_cm))
        
        # Сортируем по площади
        leaf_info.sort(key=lambda x: x[1], reverse=True)
        
        return leaf_info
    
    def get_yolo_contours(self, image: np.ndarray, detections: List[Dict]) -> List[Tuple[np.ndarray, float, float]]:
        """Преобразование YOLO детекций в контуры"""
        leaf_info = []
        leaf_detections = [d for d in detections if d['class'] == 'leaf']
        
        for det in leaf_detections:
            x1, y1, x2, y2 = det['bbox']
            # Создаём контур из bbox
            contour = np.array([
                [x1, y1],
                [x2, y1],
                [x2, y2],
                [x1, y2]
            ], dtype=np.int32)
            
            area_px = (x2 - x1) * (y2 - y1)
            area_cm = area_px / (self.pixels_per_cm ** 2)
            leaf_info.append((contour, area_px, area_cm))
        
        return leaf_info
    
    def analyze_leaf(self, contour: np.ndarray, 
                    healthy_mask: np.ndarray,
                    damage_mask: np.ndarray) -> Dict:
        """Анализ отдельного листа"""
        
        # Создаем маску листа
        leaf_mask = np.zeros_like(healthy_mask)
        cv2.drawContours(leaf_mask, [contour], -1, 255, -1)
        
        # Общая площадь листа
        total_area_px = cv2.contourArea(contour)
        total_area_cm = total_area_px / (self.pixels_per_cm ** 2)
        
        # Здоровые участки
        healthy_pixels = cv2.bitwise_and(healthy_mask, leaf_mask)
        healthy_area_px = cv2.countNonZero(healthy_pixels)
        healthy_area_cm = healthy_area_px / (self.pixels_per_cm ** 2)
        
        # Поврежденные участки
        damaged_pixels = cv2.bitwise_and(damage_mask, leaf_mask)
        damaged_area_px = cv2.countNonZero(damaged_pixels)
        damaged_area_cm = damaged_area_px / (self.pixels_per_cm ** 2)
        
        # Проценты
        if total_area_px > 0:
            healthy_percent = (healthy_area_px / total_area_px) * 100
            damaged_percent = (damaged_area_px / total_area_px) * 100
        else:
            healthy_percent = 0
            damaged_percent = 0
        
        return {
            'total_area_cm': total_area_cm,
            'healthy_area_cm': healthy_area_cm,
            'damaged_area_cm': damaged_area_cm,
            'healthy_percent': healthy_percent,
            'damaged_percent': damaged_percent,
            'leaf_mask': leaf_mask,
            'healthy_mask': healthy_pixels,
            'damage_mask': damaged_pixels
        }
    
    def analyze_image(self, image_path: str) -> Dict:
        """Полный анализ изображения"""
        try:
            original, hsv = self.preprocess_image(image_path)
            
            # Создаем маски
            healthy_mask = self.create_mask(hsv, self.healthy_ranges)
            damage_mask = self.create_mask(hsv, self.damage_ranges)
            pure_healthy = cv2.bitwise_and(healthy_mask, cv2.bitwise_not(damage_mask))
            
            # YOLO детекция
            yolo_detections = []
            if self.use_yolo and self.yolo:
                yolo_detections = self.yolo.detect(original)
                print(f"🎯 YOLO: {len([d for d in yolo_detections if d['class']=='leaf'])} листьев, "
                      f"{len([d for d in yolo_detections if d['class']=='damage'])} повреждений")
            
            # Находим листья (YOLO или цветовой метод)
            if self.use_yolo and len(yolo_detections) > 0:
                leaf_info = self.get_yolo_contours(original, yolo_detections)
                method_used = "YOLO"
            else:
                leaf_info = self.find_leaves_by_color(pure_healthy)
                method_used = "Color"
            
            # Создаем визуализацию масок
            mask_viz = self.create_mask_visualization(original, pure_healthy, damage_mask, yolo_detections)
            
            # Анализируем каждый лист
            results_list = []
            total_healthy = 0
            total_damaged = 0
            total_area = 0
            
            for contour, area_px, area_cm in leaf_info:
                leaf_result = self.analyze_leaf(contour, pure_healthy, damage_mask)
                results_list.append(leaf_result)
                total_healthy += leaf_result['healthy_area_cm']
                total_damaged += leaf_result['damaged_area_cm']
                total_area += leaf_result['total_area_cm']
            
            # Общие проценты
            if total_area > 0:
                overall_healthy = (total_healthy / total_area) * 100
                overall_damaged = (total_damaged / total_area) * 100
            else:
                overall_healthy = 0
                overall_damaged = 0
            
            # Визуализация
            visualization = self.create_result_visualization(
                original, leaf_info, results_list, yolo_detections, method_used
            )
            
            return {
                'total_leaves': len(results_list),
                'leaves': results_list,
                'total_area_cm': total_area,
                'total_healthy_cm': total_healthy,
                'total_damaged_cm': total_damaged,
                'healthy_percent': overall_healthy,
                'damaged_percent': overall_damaged,
                'method_used': method_used,
                'yolo_detections': yolo_detections,
                'visualization': visualization,
                'mask_viz': mask_viz
            }
            
        except Exception as e:
            print(f"❌ Ошибка: {e}")
            import traceback
            traceback.print_exc()
            raise
    
    def create_mask_visualization(self, img: np.ndarray, healthy_mask: np.ndarray,
                                   damage_mask: np.ndarray, detections: List[Dict]) -> np.ndarray:
        """Визуализация масок"""
        vis = img.copy()
        
        # Зеленый overlay для здоровых
        healthy_overlay = np.zeros_like(vis)
        healthy_overlay[healthy_mask > 0] = [0, 255, 0]
        cv2.addWeighted(healthy_overlay, 0.4, vis, 1.0, 0, vis)
        
        # Красный overlay для повреждений
        damaged_overlay = np.zeros_like(vis)
        damaged_overlay[damage_mask > 0] = [0, 0, 255]
        cv2.addWeighted(damaged_overlay, 0.6, vis, 1.0, 0, vis)
        
        # Рисуем YOLO боксы
        for det in detections:
            x1, y1, x2, y2 = det['bbox']
            color = (0, 255, 0) if det['class'] == 'leaf' else (0, 0, 255)
            cv2.rectangle(vis, (x1, y1), (x2, y2), color, 2)
            label = f"{det['class']}: {det['confidence']:.2f}"
            cv2.putText(vis, label, (x1, y1-5), cv2.FONT_HERSHEY_SIMPLEX, 0.4, color, 1)
        
        # Легенда
        cv2.rectangle(vis, (10, 10), (200, 70), (0, 0, 0), -1)
        cv2.putText(vis, "🟢 Здоровые участки", (15, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0, 255, 0), 1)
        cv2.putText(vis, "🔴 Повреждения", (15, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.4, (0, 0, 255), 1)
        
        return vis
    
    def create_result_visualization(self, img: np.ndarray, leaf_info: List,
                                     results: List, detections: List[Dict],
                                     method_used: str) -> np.ndarray:
        """Визуализация результатов"""
        vis = img.copy()
        
        for i, (contour, area_px, area_cm) in enumerate(leaf_info):
            if i < len(results):
                result = results[i]
                
                # Рисуем контур
                cv2.drawContours(vis, [contour], -1, (255, 255, 255), 2)
                
                # Добавляем информацию
                M = cv2.moments(contour)
                if M['m00'] != 0:
                    cx = int(M['m10'] / M['m00'])
                    cy = int(M['m01'] / M['m00'])
                    
                    # Фон для текста
                    cv2.rectangle(vis, (cx-70, cy-35), (cx+70, cy+15), (0, 0, 0), -1)
                    
                    # Текст
                    text1 = f"L{i+1}: {result['total_area_cm']:.1f}см²"
                    text2 = f"Зд:{result['healthy_percent']:.0f}% Пов:{result['damaged_percent']:.0f}%"
                    
                    cv2.putText(vis, text1, (cx-65, cy-20), cv2.FONT_HERSHEY_SIMPLEX, 0.35, (255, 255, 255), 1)
                    cv2.putText(vis, text2, (cx-65, cy), cv2.FONT_HERSHEY_SIMPLEX, 0.35, (255, 255, 255), 1)
        
        # Рисуем YOLO боксы для повреждений
        for det in detections:
            if det['class'] == 'damage':
                x1, y1, x2, y2 = det['bbox']
                cv2.rectangle(vis, (x1, y1), (x2, y2), (0, 0, 255), 1)
        
        # Общая информация
        if results:
            total_damage = sum(r['damaged_percent'] for r in results) / len(results)
            total_healthy = sum(r['healthy_percent'] for r in results) / len(results)
            info = f"{method_used} | Листьев: {len(results)} | Здоровье: {total_healthy:.0f}% | Поражение: {total_damage:.0f}%"
            
            cv2.rectangle(vis, (10, 10), (450, 35), (0, 0, 0), -1)
            cv2.putText(vis, info, (15, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (255, 255, 255), 1)
        
        return vis


