    def load_image(self):
        file_path, _ = QFileDialog.getOpenFileName(
            self, 'Выберите изображение', os.path.expanduser("~"),
            'Изображения (*.png *.jpg *.jpeg *.bmp *.tiff);;Все файлы (*.*)'
        )
        
        if file_path:
            try:
                test_img = cv2.imread(file_path)
                if test_img is None:
                    QMessageBox.critical(self, '❌ Ошибка', 'Не удалось загрузить изображение')
                    return
                
                self.current_image_path = file_path
                self.display_image(file_path, self.original_label)
                
                file_name = os.path.basename(file_path)
                file_size = os.path.getsize(file_path) / 1024
                file_size_str = f"{file_size:.1f} KB" if file_size < 1024 else f"{file_size/1024:.2f} MB"
                
                self.file_info.setText(f'📁 {file_name}\n📏 {file_size_str}')
                self.analyze_btn.setEnabled(True)
                self.status_bar.showMessage(f'✅ Загружено: {file_name}')
                
            except Exception as e:
                QMessageBox.critical(self, '❌ Ошибка', f'Ошибка: {str(e)}')
    
    def display_image(self, image_path, label_widget):
        try:
            pixmap = QPixmap(image_path)
            if not pixmap.isNull():
                scaled = pixmap.scaled(900, 600, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                label_widget.setPixmap(scaled)
                label_widget.setText("")
        except:
            label_widget.setText("❌ Ошибка загрузки")
    
    def display_cv_image(self, cv_img, label_widget):
        """Отображение OpenCV изображения в QLabel"""
        try:
            if cv_img is not None:
                rgb = cv2.cvtColor(cv_img, cv2.COLOR_BGR2RGB)
                h, w, ch = rgb.shape
                qt_img = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
                pixmap = QPixmap.fromImage(qt_img)
                scaled = pixmap.scaled(900, 600, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                label_widget.setPixmap(scaled)
                label_widget.setText("")
        except Exception as e:
            label_widget.setText(f"❌ Ошибка: {str(e)}")
    
    def analyze(self):
        if not self.current_image_path:
            return
        
        try:
            self.progress.show()
            self.progress.setValue(0)
            self.status_bar.showMessage('🔄 Анализ...')
            QApplication.processEvents()
            
            # Создаем анализатор с текущими параметрами
            self.analyzer = LeafDiseaseAnalyzer(
                pixels_per_cm=self.ppc_spin.value(),
                min_leaf_area_cm=self.min_area_spin.value(),
                use_yolo=self.yolo_checkbox.isChecked()
            )
            
            self.progress.setValue(30)
            QApplication.processEvents()
            
            # Анализируем
            self.results = self.analyzer.analyze_image(self.current_image_path)
            
            self.progress.setValue(80)
            QApplication.processEvents()
            
            # Отображаем результаты
            if 'visualization' in self.results:
                self.display_cv_image(self.results['visualization'], self.result_label)
            
            if 'mask_viz' in self.results:
                self.display_cv_image(self.results['mask_viz'], self.mask_label)
            
            self.display_results()
            
            self.progress.setValue(100)
            self.status_bar.showMessage(f'✅ Анализ завершен (метод: {self.results["method_used"]})')
            
        except Exception as e:
            QMessageBox.critical(self, '❌ Ошибка', f'Ошибка анализа:\n{str(e)}')
        finally:
            self.progress.hide()
    
    def display_results(self):
        if not self.results:
            return
        
        leaves = self.results.get('total_leaves', 0)
        total = self.results.get('total_area_cm', 0.0)
        healthy = self.results.get('total_healthy_cm', 0.0)
        damaged = self.results.get('total_damaged_cm', 0.0)
        healthy_pct = self.results.get('healthy_percent', 0.0)
        damaged_pct = self.results.get('damaged_percent', 0.0)
        method = self.results.get('method_used', 'Unknown')
        
        text = [
            "🍃 РЕЗУЛЬТАТЫ АНАЛИЗА",
            "=" * 40,
            f"🎯 Метод детекции: {method}",
            f"📊 Листьев: {leaves}",
            f"📐 Общая площадь: {total:.1f} см²",
            f"🟢 Здоровая площадь: {healthy:.1f} см² ({healthy_pct:.1f}%)",
            f"🔴 Поврежденная площадь: {damaged:.1f} см² ({damaged_pct:.1f}%)",
            f"⚠️ Общий процент поражения: {damaged_pct:.1f}%"
        ]
        
        if damaged_pct < 10:
            text.append("\n✅ Состояние: Хорошее")
        elif damaged_pct < 30:
            text.append("\n⚠️ Состояние: Среднее (требуется наблюдение)")
        else:
            text.append("\n🔴 Состояние: Плохое (требуется лечение)")
        
        if leaves > 0:
            text.append("\n📊 ПО ЛИСТЬЯМ:")
            for i, leaf in enumerate(self.results.get('leaves', [])):
                text.append(f"  Лист {i+1}: {leaf['total_area_cm']:.1f}см², "
                          f"Зд:{leaf['healthy_percent']:.0f}%, "
                          f"Пов:{leaf['damaged_percent']:.0f}%")
        
        # Добавляем информацию о YOLO детекциях
        yolo_dets = self.results.get('yolo_detections', [])
        if yolo_dets:
            leaf_count = len([d for d in yolo_dets if d['class'] == 'leaf'])
            damage_count = len([d for d in yolo_dets if d['class'] == 'damage'])
            text.append(f"\n🎯 YOLO обнаружил: {leaf_count} листьев, {damage_count} повреждений")
        
        self.results_text.setText('\n'.join(text))
    
